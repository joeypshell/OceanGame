metadata_id = "surface_base"
display_name = "Surface Base"
stable_region_name = "Surface Base"
kind = "base"
depth_band = "surface"
role = "Safe start, extraction, results, upgrades, and next-expedition briefing hub."
memory_goal = "Remember this as the safe hub above the dive, the return direction, and the place where cargo, scans, upgrades, and next-expedition briefings resolve."
persistent_facts = "Player starts here.
Extraction succeeds only after leaving and returning.
Safe return orientation should always point back here."
variable_hooks = "Shows the current expedition condition briefing before the dive."
readability_priority = "Safe return and extraction orientation."

