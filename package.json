{
  "name": "oceangame",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "playwright:install": "playwright install chromium",
    "web:export": "node tests/playwright/export-web.mjs",
    "web:serve": "node tests/playwright/serve-web.mjs",
    "map:area01": "node tools/build-area01-map.mjs --write --previews",
    "map:area01:validate": "node tools/build-area01-map.mjs --validate",
    "map:area01:all": "node tools/build-area01-map.mjs --validate --write --previews",
    "test:visual": "npm run web:export && playwright test --config tests/playwright/playwright.config.mjs",
    "test:visual:existing": "playwright test --config tests/playwright/playwright.config.mjs",
    "test:survival-loop-captures": "npm run web:export && playwright test --config tests/playwright/survival-day-night-loop.config.mjs",
    "test:survival-loop-captures:existing": "playwright test --config tests/playwright/survival-day-night-loop.config.mjs",
    "test:lower-route-smoke": "npm run web:export && playwright test --config tests/playwright/lower-route-smoke.config.mjs",
    "test:lower-route-smoke:existing": "playwright test --config tests/playwright/lower-route-smoke.config.mjs",
    "test:web-release-smoke": "npm run web:export && playwright test --config tests/playwright/web-release-smoke.config.mjs",
    "test:web-release-smoke:existing": "playwright test --config tests/playwright/web-release-smoke.config.mjs",
    "test:area01-shell-captures": "npm run web:export && playwright test --config tests/playwright/area01-shell-captures.config.mjs",
    "test:area01-shell-captures:existing": "playwright test --config tests/playwright/area01-shell-captures.config.mjs",
    "test:visual:mobile-like": "npm run web:export && playwright test --config tests/playwright/mobile-landscape.config.mjs",
    "test:visual:mobile-like:existing": "playwright test --config tests/playwright/mobile-landscape.config.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
